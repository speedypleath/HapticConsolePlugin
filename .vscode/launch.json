{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Tauri: Dev",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": ["build", "--manifest-path=src-tauri/Cargo.toml", "--no-default-features"],
                "filter": { "name": "haptic-console", "kind": "bin" }
            },
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "vite: dev server"
        },
        {
            "name": "Tauri: Attach",
            "type": "lldb",
            "request": "attach",
            "program": "${workspaceFolder}/src-tauri/target/debug/haptic-console",
            "pid": "${command:pickProcess}"
        }
    ]
}
