{
  "permissions": {
    "allow": [
      "Bash(cargo:*)",
      "Bash(cargo build:*)",
      "Bash(cargo tauri:*)",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npx:*)",
      "Bash(rustfmt:*)",
      "Bash(ls:*)",
      "Bash(find . *)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); if [[ \"$FILE\" == *.rs ]]; then rustfmt \"$FILE\" 2>/dev/null || true; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '\\n[haptic-console] Session ended. Run: cargo tauri dev'"
          }
        ]
      }
    ]
  }
}
