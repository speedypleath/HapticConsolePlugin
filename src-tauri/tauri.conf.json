{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Haptic Console",
  "version": "0.1.0",
  "identifier": "com.hapticconsole.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": { "script": "npm run dev", "cwd": ".." },
    "beforeBuildCommand": { "script": "npm run build", "cwd": ".." }
  },
  "app": {
    "windows": [
      {
        "title": "Haptic Console",
        "width": 640,
        "height": 500,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
